    "Link": {
      "type": "object",
      "description": "A hyperlink that navigates to a URL when clicked, rendered as styled link text.",
      "properties": {
        "component": {
          "const": "Link"
        },
        "text": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The link's textual content."
        },
        "href": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The URL the link navigates to when clicked."
        },
        "muted": {
          "type": "boolean",
          "default": false,
          "description": "Renders the link in a less prominent shade."
        },
        "inline": {
          "type": "boolean",
          "default": false,
          "description": "Underlines the link, for links positioned within a block of text."
        },
        "target": {
          "type": "string",
          "enum": ["_self", "_blank"],
          "default": "_self",
          "description": "Whether the linked URL opens in the same tab (`_self`) or a new tab (`_blank`)."
        },
        "accessibility": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/AccessibilityAttributes",
          "description": "Accessibility label/description for assistive technologies, e.g. a fuller link description than the visible text."
        }
      },
      "required": ["component", "text", "href"],
      "unevaluatedProperties": false
    },
    "Heading": {
      "type": "object",
      "description": "Displays a section heading with a selectable semantic level and configurable visual size. A non-interactive display primitive.",
      "properties": {
        "component": {
          "const": "Heading"
        },
        "text": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The heading's textual content."
        },
        "as": {
          "type": "string",
          "enum": ["h1", "h2", "h3", "h4", "h5", "h6"],
          "default": "h2",
          "description": "The heading element to render; selects the semantic level in the document outline, independent of visual size."
        },
        "variant": {
          "type": "string",
          "enum": ["large", "medium", "small"],
          "description": "The visual size of the heading, independent of the semantic level."
        }
      },
      "required": ["component", "text"],
      "unevaluatedProperties": false
    },
    "Label": {
      "type": "object",
      "description": "Displays a small badge of contextual metadata — such as a status or category — with a selectable color variant and size. A non-interactive display primitive.",
      "properties": {
        "component": {
          "const": "Label"
        },
        "text": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The label's textual content."
        },
        "variant": {
          "type": "string",
          "enum": [
            "default",
            "primary",
            "secondary",
            "accent",
            "success",
            "attention",
            "severe",
            "danger",
            "done",
            "sponsors"
          ],
          "default": "default",
          "description": "The color scheme of the label, signaling the kind of metadata (e.g. success, danger, attention)."
        },
        "size": {
          "type": "string",
          "enum": ["small", "large"],
          "default": "small",
          "description": "How large the label is rendered."
        }
      },
      "required": ["component", "text"],
      "unevaluatedProperties": false
    },
    "BranchName": {
      "type": "object",
      "description": "A styled label that displays the name of a branch, rendered as a link when it navigates to a destination or as plain text when the reference is contextual.",
      "properties": {
        "component": {
          "const": "BranchName"
        },
        "text": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The branch name text to display."
        },
        "href": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The URL the branch name links to; clicking the label navigates there."
        },
        "as": {
          "type": "string",
          "enum": ["a", "span"],
          "default": "a",
          "description": "The HTML element used to render the label: an anchor when the branch name navigates, a plain span when the reference is contextual text."
        }
      },
      "required": ["component", "text"],
      "unevaluatedProperties": false
    },
    "RelativeTime": {
      "type": "object",
      "description": "Displays a timestamp as localized relative time (e.g. \"3 days ago\"), an elapsed duration, or an absolute localized date, depending on format and distance from now. A non-interactive display primitive.",
      "properties": {
        "component": {
          "const": "RelativeTime"
        },
        "datetime": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The moment in time to display, as an ISO 8601 datetime string."
        },
        "format": {
          "type": "string",
          "enum": ["auto", "relative", "duration", "datetime"],
          "default": "auto",
          "description": "How to present the time: `auto` switches from relative to an absolute date past the threshold; `relative` is always relative; `duration` shows the elapsed duration; `datetime` shows an absolute localized date."
        },
        "formatStyle": {
          "type": "string",
          "enum": ["long", "short", "narrow"],
          "description": "The verbosity of the formatted output (e.g. \"3 days ago\" vs \"3d\")."
        },
        "tense": {
          "type": "string",
          "enum": ["auto", "past", "future"],
          "default": "auto",
          "description": "Which tense to render relative time in."
        },
        "precision": {
          "type": "string",
          "enum": ["year", "month", "week", "day", "hour", "minute", "second", "millisecond"],
          "default": "second",
          "description": "The smallest unit shown when displaying elapsed/duration time."
        },
        "threshold": {
          "type": "string",
          "default": "P30D",
          "description": "ISO 8601 duration beyond which display switches from relative to an absolute date."
        },
        "prefix": {
          "type": "string",
          "default": "on",
          "description": "Text prepended to an absolute date (e.g. \"on Jan 1, 2026\")."
        },
        "second": {
          "type": "string",
          "enum": ["numeric", "2-digit"],
          "description": "How the seconds part of an absolute date is rendered."
        },
        "minute": {
          "type": "string",
          "enum": ["numeric", "2-digit"],
          "description": "How the minutes part of an absolute date is rendered."
        },
        "hour": {
          "type": "string",
          "enum": ["numeric", "2-digit"],
          "description": "How the hours part of an absolute date is rendered."
        },
        "weekday": {
          "type": "string",
          "enum": ["short", "long", "narrow"],
          "description": "How the weekday part of an absolute date is rendered."
        },
        "day": {
          "type": "string",
          "enum": ["numeric", "2-digit"],
          "description": "How the day part of an absolute date is rendered."
        },
        "month": {
          "type": "string",
          "enum": ["numeric", "2-digit", "short", "long", "narrow"],
          "default": "numeric",
          "description": "How the month part of an absolute date is rendered."
        },
        "year": {
          "type": "string",
          "enum": ["numeric", "2-digit"],
          "description": "How the year part of an absolute date is rendered."
        },
        "timeZoneName": {
          "type": "string",
          "enum": ["long", "short", "shortOffset", "longOffset", "shortGeneric", "longGeneric"],
          "description": "Whether and how the time-zone name is appended to an absolute date."
        },
        "noTitle": {
          "type": "boolean",
          "description": "Suppresses the hover tooltip showing the full formatted date."
        }
      },
      "required": ["component", "datetime"],
      "unevaluatedProperties": false
    },
    "StateLabel": {
      "type": "object",
      "description": "A badge that displays the status of an item such as an issue or pull request, with an icon and color treatment matched to the state.",
      "properties": {
        "component": {
          "const": "StateLabel"
        },
        "text": {
          "$ref": "https://a2ui.org/specification/v0_9/common_types.json#/$defs/DynamicString",
          "description": "The status text to display inside the badge."
        },
        "status": {
          "type": "string",
          "enum": [
            "issueOpened",
            "issueClosed",
            "issueClosedNotPlanned",
            "pullOpened",
            "pullClosed",
            "pullMerged",
            "draft",
            "issueDraft",
            "pullQueued",
            "unavailable",
            "alertOpened",
            "alertFixed",
            "alertDismissed",
            "alertClosed",
            "open",
            "closed",
            "archived"
          ],
          "description": "The state to display; selects the badge's icon and color treatment. Covers issue and pull-request states, security-alert states, and generic open/closed/archived."
        },
        "size": {
          "type": "string",
          "enum": ["small", "medium"],
          "default": "medium",
          "description": "The badge's size."
        }
      },
      "required": ["component", "text", "status"],
      "unevaluatedProperties": false
    }
  },
  "functions": {
    "consoleLog": {
      "type": "object",
      "description": "Logs a message to the browser console. A local client-side effect.",
      "properties": {
        "call": {
          "const": "consoleLog"
        },
        "args": {
