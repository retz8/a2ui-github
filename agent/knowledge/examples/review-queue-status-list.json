{
  "name": "review-queue-status-list",
  "intent": "List the pull requests in my review queue with their current state so I can multi-select which ones to batch-review.",
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
        "surfaceId": "review-queue-status-list",
        "catalogId": "https://github.com/retz8/a2ui-github/blob/main/primer-a2ui-adapter/catalogs/v0.9.1/catalog.json"
      }
    },
    {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "review-queue-status-list",
        "components": [
          {
            "id": "root",
            "component": "Stack",
            "direction": "vertical",
            "gap": "normal",
            "children": ["heading", "list", "footer"]
          },
          {
            "id": "heading",
            "component": "Heading",
            "text": "Your review queue",
            "as": "h2",
            "variant": "medium"
          },
          {
            "id": "list",
            "component": "ActionList",
            "role": "listbox",
            "selectionVariant": "multiple",
            "showDividers": true,
            "children": {
              "componentId": "pr-row",
              "path": "/prs"
            }
          },
          {
            "id": "pr-row",
            "component": "ActionList.Item",
            "selected": {
              "path": "selected"
            },
            "children": ["pr-lv", "pr-title", "pr-desc"]
          },
          {
            "id": "pr-lv",
            "component": "ActionList.LeadingVisual",
            "children": ["pr-icon"]
          },
          {
            "id": "pr-icon",
            "component": "Icon",
            "name": "git-pull-request",
            "fill": "muted",
            "accessibility": {
              "label": "Pull request"
            }
          },
          {
            "id": "pr-title",
            "component": "Text",
            "text": {
              "path": "title"
            },
            "weight": "semibold"
          },
          {
            "id": "pr-desc",
            "component": "ActionList.Description",
            "text": {
              "path": "meta"
            },
            "variant": "block"
          },
          {
            "id": "footer",
            "component": "Stack",
            "direction": "horizontal",
            "gap": "condensed",
            "align": "center",
            "children": ["footer-text", "footer-count"]
          },
          {
            "id": "footer-text",
            "component": "Text",
            "text": "Selected for batch review",
            "size": "small"
          },
          {
            "id": "footer-count",
            "component": "CounterLabel",
            "count": {
              "path": "/selectedCount"
            },
            "variant": "primary"
          }
        ]
      }
    },
    {
      "version": "v0.9",
      "updateDataModel": {
        "surfaceId": "review-queue-status-list",
        "path": "/",
        "value": {
          "selectedCount": 0,
          "prs": [
            {
              "title": "Add incremental heal to stream parser",
              "meta": "Open · primer-a2ui-adapter · awaiting your review",
              "selected": false
            },
            {
              "title": "Spike: allowed_components pruning",
              "meta": "Draft · agent · not ready",
              "selected": false
            },
            {
              "title": "Ship StateLabel status enum",
              "meta": "Merged · primer-a2ui-adapter · follow-up review",
              "selected": false
            },
            {
              "title": "Revert experimental cache layer",
              "meta": "Closed · agent · closed without merge",
              "selected": false
            }
          ]
        }
      }
    }
  ]
}
